rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── NOTES ────────────────────────────────────────────────────
    // Extended: collaborators can now read and (if editor) update
    match /notes/{noteId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.authorId
            || request.auth.uid in resource.data.collaboratorIds
            || (
                 exists(/databases/$(database)/documents/collab_invites/$(noteId + "_" + request.auth.uid))
                 && get(/databases/$(database)/documents/collab_invites/$(noteId + "_" + request.auth.uid)).data.receiverId == request.auth.uid
               )
           );

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.authorId;

      allow update: if request.auth != null
        && request.resource.data.authorId == resource.data.authorId
        && (request.auth.uid == resource.data.authorId
            || request.auth.uid in resource.data.collaboratorIds
            || (
                 request.auth.uid in request.resource.data.collaboratorIds
                 && exists(/databases/$(database)/documents/collab_invites/$(noteId + "_" + request.auth.uid))
                 && get(/databases/$(database)/documents/collab_invites/$(noteId + "_" + request.auth.uid)).data.status == "pending"
               )
           );

      allow delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;

      // Presence subcollection for live collaboration
      match /presence/{uid} {
        allow read: if request.auth != null
          && (request.auth.uid == get(/databases/$(database)/documents/notes/$(noteId)).data.authorId
              || request.auth.uid in get(/databases/$(database)/documents/notes/$(noteId)).data.collaboratorIds);
        allow write: if request.auth != null
          && request.auth.uid == uid;
        allow delete: if request.auth != null
          && request.auth.uid == uid;
      }
    }

    // ── GROUPS (unchanged) ───────────────────────────────────────
    match /groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.authorId;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.authorId;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.authorId
        && request.resource.data.authorId == resource.data.authorId;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.authorId;
    }

    // ── USERS (NEW) ─────────────────────────────────────────────
    // Public keys must be readable by any authenticated user
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.auth.uid == uid;
      allow delete: if request.auth != null
        && request.auth.uid == uid;
    }

    // ── FRIEND REQUESTS (NEW) ───────────────────────────────────
    match /friend_requests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId
        && request.resource.data.status == "pending";

      // Only receiver can accept/reject
      allow update: if request.auth != null
        && request.auth.uid == resource.data.receiverId
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.receiverId == resource.data.receiverId
        && request.resource.data.status in ["accepted", "rejected"];

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
    }

    // ── FRIENDS (NEW) ───────────────────────────────────────────
    match /friends/{friendId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.users;

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;

      allow delete: if request.auth != null
        && request.auth.uid in resource.data.users;
    }

    // ── COLLAB INVITES (NEW) ────────────────────────────────────
    match /collab_invites/{inviteId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId;

      // Receiver can accept/reject; sender can re-invite (overwrite rejected)
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.receiverId
            || request.auth.uid == resource.data.senderId);

      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId);
    }

    // ── NOTE UPDATES (NEW) ──────────────────────────────────────
    // Encrypted CRDT updates for real-time collaboration
    match /note_updates/{updateId} {
      // FIX: Use resource.data (not request.resource.data) for reads
      allow read: if request.auth != null
        && (request.auth.uid == get(/databases/$(database)/documents/notes/$(resource.data.noteId)).data.authorId
            || request.auth.uid in get(/databases/$(database)/documents/notes/$(resource.data.noteId)).data.collaboratorIds);

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.senderId;

      // Updates are immutable — no update allowed
      allow update: if false;

      // Only note author can delete (for compaction)
      allow delete: if request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/notes/$(resource.data.noteId)).data.authorId;
    }

  }
}
